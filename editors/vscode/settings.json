{
    "workbench.colorTheme": "Atom One Light",
    "workbench.editor.empty.hint": "hidden",
    "intelephense.telemetry.enabled": false,
    "intelephense.files.maxSize": 5000000,
    "intelephense.stubs": [
        "apache", "bcmath", "bz2", "calendar", "com_dotnet",
        "Core", "curl", "date", "dba", "dom", "enchant",
        "exif", "fileinfo", "filter", "fpm", "ftp", "gd",
        "gettext", "gmp", "hash", "iconv", "imap", "intl",
        "json", "ldap", "libxml", "mbstring", "mcrypt",
        "meta", "mysqli", "oci8", "odbc", "openssl", "pcntl",
        "pcre", "PDO", "pdo_ibm", "pdo_mysql", "pdo_pgsql",
        "pdo_sqlite", "pgsql", "Phar", "posix", "pspell",
        "readline", "recode", "Reflection", "regex", "session",
        "shmop", "SimpleXML", "snmp", "soap", "sockets",
        "sodium", "SPL", "sqlite3", "standard", "superglobals",
        "sysvmsg", "sysvsem", "sysvshm", "tidy", "tokenizer",
        "xml", "xmlreader", "xmlrpc", "xmlwriter", "xsl",
        "Zend OPcache", "zip", "zlib",
        "laravel"
    ],
    "explorer.confirmDelete": false,
    "[go]": {
        "editor.insertSpaces": false,
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
            "source.organizeImports": "explicit"
        }
    },
    "github.copilot.enable": {
        "*": false,
        "plaintext": false,
        "markdown": false,
        "scminput": false
    },
    "chat.instructionsFilesLocations": {
        ".github/instructions": true,
        "/Users/ziadoz/.aitk/instructions/": true
    },
    "workbench.iconTheme": "catppuccin-latte",
    "editor.fontFamily": "JetBrains Mono, Menlo, Monaco, 'Courier New', monospace",
    "editor.fontSize": 13,
    "editor.lineHeight": 1.6,
    "files.trimTrailingWhitespace": true,
    "files.insertFinalNewline": true,
    "claudeCode.preferredLocation": "panel",
    "git.autofetch": true,
    "search.useIgnoreFiles": false,
    "chat.disableAIFeatures": true
}