#!/usr/bin/env bash
set -euo pipefail

# @see: https://evanhahn.com/scripts-i-wrote-that-i-use-all-the-time/

if [ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ]; then
    echo "Duck"
    echo "Open DuckDuckGo search from the terminal"
    echo "Usage: duck [search terms]"
    exit 0
fi

if [ $# -eq 0 ]; then
    open 'https://duckduckgo.com'
else
    args="$*"
    search="${args// /+}"

    open "https://duckduckgo.com/?q=$search"
fi
