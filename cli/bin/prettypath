#!/usr/bin/env bash
set -euo pipefail

# @see: https://evanhahn.com/scripts-i-wrote-that-i-use-all-the-time/

if [ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ]; then
    echo "Pretty Path"
    echo 'Print $PATH with one entry per line'
    echo "Usage: prettypath"
    exit 0
fi

echo "$PATH" | tr ':' '\n'
