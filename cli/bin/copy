#!/usr/bin/env bash
set -euo pipefail

# @see: https://evanhahn.com/scripts-i-wrote-that-i-use-all-the-time/

if { [ -t 0 ] && [ $# -eq 0 ]; } || [ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ]; then
    echo "Copy"
    echo "Copy stdin to clipboard"
    echo 'Usage: echo "hello" | copy'
    exit 0
fi

pbcopy
