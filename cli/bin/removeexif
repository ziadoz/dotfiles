#!/usr/bin/env bash
set -euo pipefail

# @see: https://evanhahn.com/scripts-i-wrote-that-i-use-all-the-time/

if [ $# -eq 0 ] || [ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ]; then
    echo "Remove EXIF"
    echo "Strip EXIF data from JPEGs"
    echo "Usage: removeexif image.jpg [image2.jpg ...]"
    exit 0
fi

exec jhead -purejpg "$@"
