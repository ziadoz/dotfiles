#!/usr/bin/env bash
set -euo pipefail

# @see: https://evanhahn.com/scripts-i-wrote-that-i-use-all-the-time/

if [ $# -eq 0 ] || [ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ]; then
    echo "Mksh"
    echo "Create a new shell script with shebang and open in editor"
    echo "Usage: mksh scriptname"
    exit 0
fi

printf '#!/usr/bin/env bash\nset -euo pipefail\n\n' > "$1"
chmod +x "$1"
exec "${EDITOR:-vim}" "$1"
