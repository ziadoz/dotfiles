#!/usr/bin/env bash
set -euo pipefail

# Mksh
# Create a new shell script with shebang and open in editor
# Usage: mksh scriptname
# @see: https://evanhahn.com/scripts-i-wrote-that-i-use-all-the-time/

if [[ $# != 1 ]]; then
    echo "Usage: mksh <filename>" >&2
    exit 1
fi

printf '#!/usr/bin/env bash\nset -euo pipefail\n\n' > "$1"
chmod +x "$1"
exec "${EDITOR:-vim}" "$1"
