#!/usr/bin/env bash
set -euo pipefail

# @see: https://evanhahn.com/scripts-i-wrote-that-i-use-all-the-time/

if [ $# -eq 0 ] || [ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ]; then
    echo "Cat Bin"
    echo 'Display the source of a script in your $PATH'
    echo "Usage: catbin scriptname"
    exit 0
fi

if command -v bat &>/dev/null; then
    cat_command=bat
else
    cat_command=cat
fi

exec "$cat_command" "$(command -v "$1")"
