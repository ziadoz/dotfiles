#!/usr/bin/env python3

# @see: https://evanhahn.com/scripts-i-wrote-that-i-use-all-the-time/

import sys
import unicodedata

if len(sys.argv) < 2 or sys.argv[1] in ("-h", "--help"):
    print("Unicode Codepoint")
    print("Look up Unicode character by hex codepoint")
    print("Usage: u+ 1F600")
    sys.exit(0)

as_int = int(sys.argv[1], 16)
as_chr = chr(as_int)

print(as_chr)
print(unicodedata.name(as_chr))
