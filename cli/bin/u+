#!/usr/bin/env python3

# U+
# Look up Unicode character by hex codepoint
# Usage: u+ 1F600
# @see: https://evanhahn.com/scripts-i-wrote-that-i-use-all-the-time/

import sys
import unicodedata

if len(sys.argv) != 2:
    print("Usage: u+ <hex_codepoint>", file=sys.stderr)
    sys.exit(1)

as_int = int(sys.argv[1], 16)
as_chr = chr(as_int)

print(as_chr)
print(unicodedata.name(as_chr))
