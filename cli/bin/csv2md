#!/usr/bin/env python3

# @see: https://evanhahn.com/scripts-i-wrote-that-i-use-all-the-time/

import csv
import sys

if (sys.stdin.isatty() and len(sys.argv) == 1) or (len(sys.argv) > 1 and sys.argv[1] in ("-h", "--help")):
    print("CSV to Markdown")
    print("Convert CSV to Markdown table")
    print("Usage: csv2md < file.csv")
    sys.exit(0)

reader = csv.reader(sys.stdin)
rows = list(reader)

if not rows:
    sys.exit(0)

header = rows[0]
print("| " + " | ".join(header) + " |")
print("| " + " | ".join("---" for _ in header) + " |")

for row in rows[1:]:
    print("| " + " | ".join(row) + " |")
