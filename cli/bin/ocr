#!/usr/bin/env bash
set -euo pipefail

# Ocr
# Extract text from images using macOS built-in OCR
# Usage: ocr image.png
# @see: https://evanhahn.com/scripts-i-wrote-that-i-use-all-the-time/
# @see: https://blog.greg.technology/2024/01/02/how-do-you-ocr-on-a-mac.html

shortcuts run "Extract Text from Image" -i "$1"
