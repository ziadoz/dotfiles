#!/usr/bin/env bash
set -euo pipefail

# @see: https://evanhahn.com/scripts-i-wrote-that-i-use-all-the-time/

if [ $# -eq 0 ] || [ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ]; then
    echo "Length"
    echo "Count characters in arguments"
    echo 'Usage: length "some text"'
    exit 0
fi

echo -n "$@" | wc -c | awk '{print $1}'
