#!/usr/bin/env python3

# Markdownquote
# Prefix stdin lines with > for Markdown quoting
# Usage: echo "some text" | markdownquote
# @see: https://evanhahn.com/scripts-i-wrote-that-i-use-all-the-time/

import sys

for line in sys.stdin:
    trimmed = line.strip()
    if trimmed == "":
        print(">")
    elif trimmed.startswith(">"):
        print(trimmed)
    else:
        print("> " + trimmed)
