#!/usr/bin/env bash
set -euo pipefail

# @see: https://evanhahn.com/scripts-i-wrote-that-i-use-all-the-time/

if [ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ]; then
    echo "Running"
    echo "List running processes with optional grep filtering"
    echo "Usage: running [search term]"
    exit 0
fi

process_list="$(ps -eo 'pid command')"

if [[ $# != 0 ]]; then
    process_list="$(echo "$process_list" | grep -iF "$*")"
fi

echo "$process_list" |
    grep -Fv "${BASH_SOURCE[0]}" |
    grep -Fv grep
