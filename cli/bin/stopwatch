#!/usr/bin/env bash
set -euo pipefail

# @see: https://evanhahn.com/scripts-i-wrote-that-i-use-all-the-time/

if [ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ]; then
    echo "Stopwatch"
    echo "Simple terminal stopwatch (Ctrl+D to stop)"
    echo "Usage: stopwatch"
    exit 0
fi

date "+%l:%M:%S%p: stopwatch started (^D to stop)"
time cat
date "+%l:%M:%S%p: stopwatch stopped"
