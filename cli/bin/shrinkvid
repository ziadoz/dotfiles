#!/usr/bin/env bash
set -euo pipefail

# Shrinkvid
# Compress video via ffmpeg (CRF encoding)
# Usage: shrinkvid input.mp4 [output.mp4] [crf]
# @see: https://evanhahn.com/scripts-i-wrote-that-i-use-all-the-time/

input="$1"
output="${2:-${input%.*}-shrunk.${input##*.}}"
crf="${3:-28}"

ffmpeg -i "$input" -vcodec libx264 -crf "$crf" "$output"
