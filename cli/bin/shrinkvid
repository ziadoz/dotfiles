#!/usr/bin/env bash
set -euo pipefail

# @see: https://evanhahn.com/scripts-i-wrote-that-i-use-all-the-time/

if [ $# -eq 0 ] || [ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ]; then
    echo "Shrink Video"
    echo "Compress video via ffmpeg (CRF encoding)"
    echo "Usage: shrinkvid input.mp4 [output.mp4] [crf]"
    exit 0
fi

input="$1"
output="${2:-${input%.*}-shrunk.${input##*.}}"
crf="${3:-28}"

ffmpeg -i "$input" -vcodec libx264 -crf "$crf" "$output"
