#!/usr/bin/env bash
set -euo pipefail

# @see: https://evanhahn.com/scripts-i-wrote-that-i-use-all-the-time/

if { [ -t 0 ] && [ $# -eq 0 ]; } || [ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ]; then
    echo "JSON Format"
    echo "Pretty-print JSON from stdin"
    echo "Usage: echo '{\"key\":\"value\"}' | jsonformat"
    exit 0
fi

if command -v jq &>/dev/null; then
    jq .
else
    python3 -m json.tool
fi
