#!/usr/bin/env python3

# Each
# Run a command for each line of stdin
# Usage: ls | each "echo processing {}"
# @see: https://evanhahn.com/scripts-i-wrote-that-i-use-all-the-time/

import shlex
import subprocess
import sys

if len(sys.argv) != 2 or "{}" not in sys.argv[1]:
    print("Usage: each 'command {}'", file=sys.stderr)
    print("  {} is replaced with each line from stdin", file=sys.stderr)
    sys.exit(1)

command = sys.argv[1]

for line in sys.stdin:
    line = line.strip()
    if line == "":
        continue
    result = subprocess.run(
        command.replace("{}", shlex.quote(line)),
        shell=True,
        check=False,
    )
    if result.returncode != 0:
        sys.exit(result.returncode)
