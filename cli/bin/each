#!/usr/bin/env python3

# @see: https://evanhahn.com/scripts-i-wrote-that-i-use-all-the-time/

import shlex
import subprocess
import sys

if len(sys.argv) < 2 or sys.argv[1] in ("-h", "--help"):
    print("Each")
    print("Run a command for each line of stdin")
    print('Usage: ls | each "echo processing {}"')
    sys.exit(0)

if "{}" not in sys.argv[1]:
    print("Each: missing {} placeholder", file=sys.stderr)
    sys.exit(1)

command = sys.argv[1]

for line in sys.stdin:
    line = line.strip()
    if line == "":
        continue
    result = subprocess.run(
        command.replace("{}", shlex.quote(line)),
        shell=True,
        check=False,
    )
    if result.returncode != 0:
        sys.exit(result.returncode)
