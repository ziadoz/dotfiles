#!/usr/bin/env python3

# Extensions
# List unique file extensions from stdin
# Usage: find . | extensions
# @see: https://evanhahn.com/scripts-i-wrote-that-i-use-all-the-time/

import os
import sys

seen = set()
for line in sys.stdin:
    _, ext = os.path.splitext(line.strip())
    if len(ext) > 1 and ext not in seen:
        print(ext)
        seen.add(ext)
