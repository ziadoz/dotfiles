#!/usr/bin/env python3

# @see: https://evanhahn.com/scripts-i-wrote-that-i-use-all-the-time/

import os
import sys

if (sys.stdin.isatty() and len(sys.argv) == 1) or (len(sys.argv) > 1 and sys.argv[1] in ("-h", "--help")):
    print("Extensions")
    print("List unique file extensions from stdin")
    print("Usage: find . | extensions")
    sys.exit(0)

seen = set()
for line in sys.stdin:
    _, ext = os.path.splitext(line.strip())
    if len(ext) > 1 and ext not in seen:
        print(ext)
        seen.add(ext)
