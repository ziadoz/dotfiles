#!/usr/bin/env bash
set -euo pipefail

# @see: https://evanhahn.com/scripts-i-wrote-that-i-use-all-the-time/

if [ $# -eq 0 ] || [ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ]; then
    echo "Get Song"
    echo "Download audio via yt-dlp (best quality)"
    echo "Usage: getsong <url>"
    exit 0
fi

yt-dlp --extract-audio --audio-format mp3 --audio-quality 0 "$1"
