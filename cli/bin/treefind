#!/usr/bin/env bash
set -euo pipefail

# @see: https://evanhahn.com/scripts-i-wrote-that-i-use-all-the-time/

if [ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ]; then
    echo "Tree Find"
    echo "Tree with search/filter via pattern matching"
    echo "Usage: treefind [pattern] [directory]"
    exit 0
fi

if [[ $# == 0 ]]; then
    tree .
    exit 0
elif [[ $# == 1 ]]; then
    what="$1"
    where="$(pwd)"
elif [[ $# == 2 ]]; then
    what="$1"
    where="$2"
else
    echo "Usage: treefind [pattern] [directory]" >&2
    exit 1
fi

if [[ "$what" == *[[:upper:]]* ]]; then
    ignore_case_arg=''
else
    ignore_case_arg='--ignore-case'
fi

tree --prune $ignore_case_arg --matchdirs -P "$what" "$where"
