#!/usr/bin/env bash
set -euo pipefail

# @see: https://evanhahn.com/scripts-i-wrote-that-i-use-all-the-time/

if [ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ]; then
    echo "Scratch"
    echo 'Open a temp file in $EDITOR'
    echo "Usage: scratch"
    exit 0
fi

file="$(mktemp)"

echo "Editing $file"
exec "${EDITOR:-vim}" "$file"
