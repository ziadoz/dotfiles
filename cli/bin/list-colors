#!/usr/bin/env bash
set -euo pipefail

# @see: https://evanhahn.com/scripts-i-wrote-that-i-use-all-the-time/

if [ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ]; then
    echo "List Colors"
    echo "Display all 256 terminal colors"
    echo "Usage: list-colors"
    exit 0
fi

for i in {0..255}; do
    printf "\e[38;5;%sm%3s " "$i" "$i"
done
echo
