#!/usr/bin/env bash
set -euo pipefail

# @see: https://evanhahn.com/scripts-i-wrote-that-i-use-all-the-time/

if { [ -t 0 ] && [ $# -eq 0 ]; } || [ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ]; then
    echo "Uppered"
    echo "Convert stdin to uppercase"
    echo 'Usage: echo "hello" | uppered'
    exit 0
fi

tr '[:lower:]' '[:upper:]'
