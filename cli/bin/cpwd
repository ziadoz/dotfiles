#!/usr/bin/env bash
set -euo pipefail

# @see: https://evanhahn.com/scripts-i-wrote-that-i-use-all-the-time/

if [ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ]; then
    echo "Copy PWD"
    echo "Copy current working directory to clipboard"
    echo "Usage: cpwd"
    exit 0
fi

pwd | pbcopy
echo "Copied: $(pwd)"
